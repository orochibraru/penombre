{
	"branches": ["main"],
	"plugins": [
		[
			"@semantic-release/commit-analyzer",
			{
				"releaseRules": [
					{
						"breaking": true,
						"release": "major"
					},
					{
						"type": "feat",
						"release": "patch"
					},
					{
						"type": "fix",
						"release": "patch"
					},
					{
						"type": "perf",
						"release": "patch"
					},
					{
						"type": "revert",
						"release": "patch"
					}
				]
			}
		],
		[
			"@semantic-release/release-notes-generator",
			{
				"writerOpts": {
					"footerPartial": "---\n\n## 🐳 Docker\n\n```sh\ndocker pull orochibraru/penombre:{{version}}\n```\n\n[View on Docker Hub](https://hub.docker.com/r/orochibraru/penombre)\n"
				}
			}
		],
		[
			"@semantic-release/changelog",
			{
				"changelogFile": "CHANGELOG.md"
			}
		],
		[
			"@semantic-release/npm",
			{
				"npmPublish": false
			}
		],
		"@semantic-release/github",
		[
			"@semantic-release/git",
			{
				"assets": ["CHANGELOG.md", "package.json"],
				"message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
			}
		]
	]
}
