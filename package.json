{
	"name": "opendrive",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.11.0",
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"start": "tsx ./build/index.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky || true",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write --log-level warn .",
		"format:check": "prettier --check --log-level warn .",
		"lint": "biome check ./src/**/*.ts",
		"lint:fix": "biome check --fix ./src/**/*.ts",
		"circular": "tsx scripts/circular.ts",
		"db:generate": "pnpm exec @better-auth/cli generate --y --output src/lib/server/db/schema/auth.ts && drizzle-kit generate",
		"db:migrate": "tsx scripts/db/migrate.ts",
		"db:diagram": "tsx scripts/db-diagram.ts && dbml-renderer -i ./docs/db-diagram.dbml -o docs/db-diagram.svg",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.5",
		"@dnd-kit-svelte/core": "^0.0.8",
		"@dnd-kit-svelte/modifiers": "^0.0.8",
		"@dnd-kit-svelte/sortable": "^0.0.8",
		"@dnd-kit-svelte/utilities": "^0.0.8",
		"@softwaretechnik/dbml-renderer": "^1.0.30",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^5.1.0",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.1.10",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.7",
		"@types/madge": "^5.0.3",
		"@types/node": "^24.0.4",
		"drizzle-dbml-generator": "^0.10.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^16.1.2",
		"madge": "^8.0.0",
		"prettier": "^3.6.1",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.13",
		"svelte": "^5.34.8",
		"svelte-check": "^4.2.2",
		"tailwindcss": "^4.1.10",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3",
		"vite": "npm:rolldown-vite@^7.0.1",
		"vite-plugin-kit-routes": "^1.0.2"
	},
	"dependencies": {
		"@elysiajs/bearer": "^1.3.0",
		"@elysiajs/cors": "^1.3.3",
		"@elysiajs/eden": "^1.3.2",
		"@elysiajs/swagger": "^1.3.0",
		"@happy-dom/global-registrator": "^18.0.1",
		"@internationalized/date": "^3.8.2",
		"@kitql/helpers": "^0.8.13",
		"@lucide/svelte": "^0.523.0",
		"@tabler/icons-svelte": "^3.34.0",
		"@tanstack/table-core": "^8.21.3",
		"better-auth": "^1.2.10",
		"bits-ui": "^2.8.8",
		"clsx": "^2.1.1",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"dotenv": "^16.5.0",
		"drizzle-kit": "^0.31.2",
		"drizzle-orm": "^0.44.2",
		"elysia": "^1.3.5",
		"esbuild": "^0.25.5",
		"formsnap": "^2.0.1",
		"layerchart": "2.0.0-next.19",
		"minio": "^8.0.5",
		"mode-watcher": "^1.0.8",
		"nanoid": "^5.1.5",
		"node-cache": "^5.1.2",
		"paneforge": "1.0.0",
		"postgres": "^3.4.7",
		"svelte-sonner": "^1.0.5",
		"sveltekit-superforms": "^2.27.0",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^1.0.0",
		"tw-animate-css": "^1.3.4",
		"valibot": "^1.1.0",
		"vaul-svelte": "1.0.0-next.7",
		"zod": "^3.25.67"
	}
}
