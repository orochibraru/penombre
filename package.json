{
	"name": "@opendrive/root",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"packageManager": "bun@1.3.1",
	"scripts": {
		"prepare": "husky",
		"preinstall": "bunx only-allow bun",
		"test": "bun test",
		"build": "bun run --workspaces build",
		"dev": "bun --env-file .env concurrently.config.ts",
		"db:diagram": "bunx sql2dbml packages/api/drizzle/0000_empty_tomorrow_man.sql --postgres -o resources/db/opendrive.dbml && dbml-renderer -i resources/db/opendrive.dbml -o resources/db/opendrive.svg",
		"check": "bun run --workspaces check",
		"lint": "bunx --bun biome check .",
		"lint:fix": "bunx --bun biome check --fix . && bun run format",
		"format": "bunx --bun biome format . --write",
		"format:check": "bunx --bun biome format .",
		"circular": "bun run ./scripts/circular.ts"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@dbml/cli": "^5.3.1",
		"@happy-dom/global-registrator": "^20.1.0",
		"@softwaretechnik/dbml-renderer": "^1.0.31",
		"@testing-library/svelte": "^5.3.1",
		"@types/bun": "^1.3.5",
		"@types/madge": "^5.0.3",
		"@types/node": "^24.10.4",
		"concurrently": "^9.2.1",
		"husky": "^9.1.7",
		"madge": "^8.0.0",
		"wait-on": "^9.0.3"
	},
	"peerDependencies": {
		"typescript": "^5.9.3",
		"openapi-fetch": "^0.14.1",
		"koritsu": "^0.1.19",
		"valibot": "^1.2.0"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"@internationalized/date": "^3.10.1",
		"@kitql/helpers": "^0.8.13",
		"@lucide/svelte": "^0.545.0",
		"better-auth": "^1.4.10",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"hono": "^4.11.3",
		"layerchart": "2.0.0-next.19",
		"mode-watcher": "^1.1.0",
		"music-metadata": "^11.10.5",
		"nodemailer": "^7.0.12",
		"openapi-fetch": "^0.14.1",
		"paneforge": "1.0.2",
		"svelte-sonner": "^1.0.7",
		"sveltekit-superforms": "^2.29.1",
		"tw-animate-css": "^1.4.0",
		"uuid": "^13.0.0",
		"valibot": "^1.2.0",
		"vaul-svelte": "1.0.0-next.7",
		"zod": "^4.3.5"
	},
	"resolutions": {
		"svelte": "^5.43.15",
		"lightningcss": "1.30.1",
		"react-test-renderer": "19.1.0"
	},
	"workspaces": [
		"packages/*"
	]
}
