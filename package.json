{
	"name": "opendrive",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "bun@1.2.6",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "bun ./build/index.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky || true",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write --log-level warn .",
		"format:check": "prettier --check --log-level warn .",
		"lint": "biome check ./src",
		"lint:fix": "biome check --fix ./src",
		"test:unit": "vitest run",
		"circular": "bun scripts/madge.ts",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"db:generate": "bunx @better-auth/cli generate --y --output src/lib/server/db/schema/auth.ts && drizzle-kit generate",
		"db:migrate": "bun scripts/db/migrate.ts",
		"db:diagram": "bun scripts/db/diagram.ts && dbml-renderer -i ./docs/db-diagram.dbml -o docs/db-diagram.svg",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@dnd-kit-svelte/core": "^0.0.8",
		"@dnd-kit-svelte/modifiers": "^0.0.8",
		"@dnd-kit-svelte/sortable": "^0.0.8",
		"@dnd-kit-svelte/utilities": "^0.0.8",
		"@playwright/test": "^1.49.1",
		"@softwaretechnik/dbml-renderer": "^1.0.30",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.4",
		"@types/bun": "^1.2.16",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.7",
		"@types/node": "^22",
		"@vitest/coverage-v8": "^3.2.3",
		"drizzle-dbml-generator": "^0.10.0",
		"husky": "^9.1.7",
		"jsdom": "^26.0.0",
		"lint-staged": "^16.1.0",
		"madge": "^8.0.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.0.0",
		"svelte-adapter-bun": "^0.5.2",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.2.6",
		"vite-plugin-kit-routes": "^1.0.2",
		"vitest": "^3.2.3"
	},
	"dependencies": {
		"@elysiajs/bearer": "^1.3.0",
		"@elysiajs/cors": "^1.3.3",
		"@elysiajs/eden": "^1.3.2",
		"@elysiajs/swagger": "^1.3.0",
		"@internationalized/date": "^3.8.2",
		"@kitql/helpers": "^0.8.13",
		"@lucide/svelte": "^0.513.0",
		"@tabler/icons-svelte": "^3.34.0",
		"@tanstack/table-core": "^8.21.3",
		"better-auth": "^1.2.9",
		"bits-ui": "^2.6.0",
		"clsx": "^2.1.1",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"dotenv": "^16.5.0",
		"drizzle-kit": "^0.30.2",
		"drizzle-orm": "^0.40.0",
		"elysia": "^1.3.4",
		"formsnap": "^2.0.1",
		"layerchart": "2.0.0-next.19",
		"minio": "^8.0.5",
		"mode-watcher": "^1.0.8",
		"nanoid": "^5.1.5",
		"node-cache": "^5.1.2",
		"paneforge": "1.0.0-next.5",
		"postgres": "^3.4.5",
		"svelte-french-toast": "^1.2.0",
		"svelte-sonner": "^1.0.5",
		"sveltekit-superforms": "^2.26.1",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^1.0.0",
		"tw-animate-css": "^1.3.4",
		"vaul-svelte": "1.0.0-next.7",
		"zod": "^3.25.64"
	}
}
