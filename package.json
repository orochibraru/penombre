{
	"name": "@penombre/root",
	"version": "1.2.24",
	"description": "",
	"main": "index.js",
	"packageManager": "bun@1.3.10",
	"scripts": {
		"prepare": "husky",
		"preinstall": "bunx only-allow bun",
		"test": "bun test '.test.'",
		"build": "bun run --filter @penombre/web build",
		"dev": "bun --env-file .env concurrently.config.ts",
		"db:diagram": "bun run ./scripts/db-diagram.ts",
		"check": "bun run --workspaces check",
		"lint": "bunx --bun biome check .",
		"lint:fix": "bunx --bun biome check --fix . && bun run format",
		"format": "bunx --bun biome format . --write",
		"format:check": "bunx --bun biome format .",
		"circular": "bun run ./scripts/circular.ts",
		"backup": "./scripts/backup.sh",
		"restore": "./scripts/restore.sh",
		"gen:api": "bun run ./scripts/gen-api.ts"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@dbml/cli": "^5.5.1",
		"@softwaretechnik/dbml-renderer": "^1.0.31",
		"@types/bun": "^1.3.10",
		"@types/madge": "^5.0.3",
		"@types/node": "^24.12.0",
		"concurrently": "^9.2.1",
		"drizzle-dbml-generator": "^0.10.0",
		"husky": "^9.1.7",
		"madge": "^8.0.0",
		"wait-on": "^9.0.4"
	},
	"workspaces": [
		"packages/*"
	]
}
