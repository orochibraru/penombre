{
	"name": "opendrive",
	"private": true,
	"version": "0.0.7",
	"type": "module",
	"packageManager": "pnpm@10.12.4",
	"scripts": {
		"dev": "vite dev",
		"dev:silent": "vite dev --logLevel warn",
		"build": "svelte-kit sync && vite build",
		"start": "tsx ./build/index.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "node --env-file=./tests/test.env ./node_modules/vitest/vitest.mjs run",
		"test:ci": "CI=true vitest run",
		"circular": "tsx circular.ts",
		"lint": "biome check ./src/",
		"lint:fix": "biome check --fix ./src/ && pnpm format",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"format": "prettier --write --log-level warn .",
		"format:check": "prettier --check --log-level warn .",
		"gen:api": "openapi-typescript ../api/public/openapi.json -o ./src/lib/api/schema.d.ts",
		"gen:routes": "kit-routes sync"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@capacitor/cli": "^7.4.2",
		"@dnd-kit-svelte/core": "^0.0.11",
		"@dnd-kit-svelte/modifiers": "^0.0.11",
		"@dnd-kit-svelte/sortable": "^0.0.11",
		"@dnd-kit-svelte/utilities": "^0.0.11",
		"@shikijs/langs": "^3.10.0",
		"@shikijs/themes": "^3.10.0",
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.33.1",
		"@sveltejs/vite-plugin-svelte": "^6.1.3",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.1.12",
		"@testcontainers/postgresql": "^11.5.1",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.7",
		"@types/madge": "^5.0.3",
		"@types/mime-types": "^3.0.1",
		"@types/node": "^24.3.0",
		"bits-ui": "^2.9.4",
		"changelogen": "^0.6.2",
		"clsx": "^2.1.1",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^16.1.5",
		"madge": "^8.0.0",
		"openapi-typescript": "^7.9.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"runed": "^0.31.1",
		"shiki": "^3.10.0",
		"svelte": "^5.38.2",
		"svelte-check": "^4.3.1",
		"svelte-toolbelt": "^0.9.3",
		"sveltekit-sse": "^0.14.3",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^2.1.0",
		"tailwindcss": "^4.1.12",
		"tsx": "^4.20.4",
		"typescript": "^5.9.2",
		"vite": "^7.1.3",
		"vite-plugin-kit-routes": "^1.0.2",
		"vitepress": "^1.6.4",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@capacitor/android": "^7.4.2",
		"@capacitor/core": "^7.4.2",
		"@capacitor/ios": "^7.4.2",
		"@happy-dom/global-registrator": "^18.0.1",
		"@internationalized/date": "^3.8.2",
		"@kitql/helpers": "^0.8.13",
		"@lucide/svelte": "^0.540.0",
		"@tanstack/table-core": "^8.21.3",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"dotenv": "^17.2.1",
		"esbuild": "^0.25.9",
		"formsnap": "^2.0.1",
		"layerchart": "2.0.0-next.19",
		"mime-types": "^3.0.1",
		"mode-watcher": "^1.1.0",
		"music-metadata": "^11.8.3",
		"nanoid": "^5.1.5",
		"openapi-fetch": "^0.14.0",
		"paneforge": "1.0.2",
		"picocolors": "^1.1.1",
		"svelte-pdf": "^1.0.28",
		"svelte-sonner": "^1.0.5",
		"sveltekit-superforms": "^2.27.1",
		"tw-animate-css": "^1.3.7",
		"uuid": "^11.1.0",
		"valibot": "^1.1.0",
		"vaul-svelte": "1.0.0-next.7",
		"zod": "^4.0.17"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"cpu-features",
			"esbuild",
			"msgpackr-extract",
			"protobufjs",
			"ssh2"
		]
	}
}
