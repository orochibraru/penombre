{
	"name": "opendrive",
	"private": true,
	"version": "0.0.7",
	"type": "module",
	"packageManager": "pnpm@10.12.4",
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"start": "tsx ./build/index.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky || true",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && pnpm run format",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write --log-level warn .",
		"format:check": "prettier --check --log-level warn .",
		"test": "node --env-file=./tests/test.env ./node_modules/vitest/vitest.mjs run",
		"test:ci": "CI=true vitest run",
		"lint": "biome check ./src/",
		"lint:fix": "biome check --fix ./src/ && pnpm format",
		"circular": "tsx scripts/circular.ts",
		"db:generate": "pnpm exec @better-auth/cli generate --y --output src/lib/server/db/schema/auth.ts && drizzle-kit generate",
		"db:migrate": "tsx scripts/migrate.ts",
		"db:diagram": "tsx scripts/db-diagram.ts && dbml-renderer -i ./diagrams/db-diagram.dbml -o diagrams/db-diagram.svg",
		"db:studio": "drizzle-kit studio",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.1.1",
		"@dnd-kit-svelte/core": "^0.0.8",
		"@dnd-kit-svelte/modifiers": "^0.0.8",
		"@dnd-kit-svelte/sortable": "^0.0.8",
		"@dnd-kit-svelte/utilities": "^0.0.8",
		"@lucide/svelte": "^0.525.0",
		"@softwaretechnik/dbml-renderer": "^1.0.31",
		"@sveltejs/adapter-node": "^5.2.13",
		"@sveltejs/kit": "^2.22.3",
		"@sveltejs/vite-plugin-svelte": "^5.1.0",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.1.11",
		"@testcontainers/postgresql": "^11.2.1",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.7",
		"@types/madge": "^5.0.3",
		"@types/mime-types": "^3.0.1",
		"@types/node": "^24.0.12",
		"changelogen": "^0.6.2",
		"drizzle-dbml-generator": "^0.10.0",
		"husky": "^9.1.7",
		"jsdom": "^26.1.0",
		"lint-staged": "^16.1.2",
		"madge": "^8.0.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.13",
		"svelte": "^5.35.5",
		"svelte-check": "^4.2.2",
		"sveltekit-sse": "^0.14.1",
		"tailwindcss": "^4.1.11",
		"testcontainers": "^11.2.1",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3",
		"vite": "^7.0.3",
		"vite-plugin-kit-routes": "^1.0.2",
		"vitepress": "^1.6.3",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.842.0",
		"@aws-sdk/s3-request-presigner": "^3.842.0",
		"@elysiajs/bearer": "^1.3.0",
		"@elysiajs/cors": "^1.3.3",
		"@elysiajs/eden": "^1.3.2",
		"@elysiajs/swagger": "^1.3.1",
		"@happy-dom/global-registrator": "^18.0.1",
		"@internationalized/date": "^3.8.2",
		"@kitql/helpers": "^0.8.13",
		"@sentry/sveltekit": "^9.36.0",
		"@tanstack/table-core": "^8.21.3",
		"better-auth": "^1.2.12",
		"bits-ui": "^2.8.10",
		"bullmq": "^5.56.2",
		"clsx": "^2.1.1",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"dotenv": "^17.2.0",
		"drizzle-kit": "^0.31.4",
		"drizzle-orm": "^0.44.2",
		"elysia": "^1.3.5",
		"esbuild": "^0.25.6",
		"formsnap": "^2.0.1",
		"layerchart": "2.0.0-next.19",
		"media-chrome": "^4.12.0",
		"mime-types": "^3.0.1",
		"mode-watcher": "^1.1.0",
		"music-metadata": "^11.6.0",
		"nanoid": "^5.1.5",
		"paneforge": "1.0.0",
		"picocolors": "^1.1.1",
		"player.style": "^0.1.9",
		"postgres": "^3.4.7",
		"svelte-sonner": "^1.0.5",
		"sveltekit-superforms": "^2.27.1",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^1.0.0",
		"tw-animate-css": "^1.3.5",
		"uuid": "^11.1.0",
		"valibot": "^1.1.0",
		"vaul-svelte": "1.0.0-next.7",
		"zod": "^3.25.76"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"@tailwindcss/oxide",
			"cpu-features",
			"esbuild",
			"protobufjs",
			"ssh2"
		]
	}
}
