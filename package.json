{
	"name": "@penombre/root",
	"version": "1.2.22",
	"description": "",
	"main": "index.js",
	"packageManager": "bun@1.3.10",
	"scripts": {
		"prepare": "husky",
		"preinstall": "bunx only-allow bun",
		"test": "bun test '.test.'",
		"build": "bun run --filter @penombre/web build",
		"dev": "bun --env-file .env concurrently.config.ts",
		"db:diagram": "bun run ./scripts/db-diagram.ts",
		"check": "bun run --workspaces check",
		"lint": "bunx --bun biome check .",
		"lint:fix": "bunx --bun biome check --fix . && bun run format",
		"format": "bunx --bun biome format . --write",
		"format:check": "bunx --bun biome format .",
		"circular": "bun run ./scripts/circular.ts",
		"backup": "./scripts/backup.sh",
		"restore": "./scripts/restore.sh",
		"gen:api": "bun run --workspaces gen:api",
		"bump": "bun run ./scripts/bump-version.ts",
		"release": "bun run ./scripts/release.ts"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@dbml/cli": "^5.4.1",
		"@happy-dom/global-registrator": "^20.4.0",
		"@softwaretechnik/dbml-renderer": "^1.0.31",
		"@testing-library/svelte": "^5.3.1",
		"@types/bun": "^1.3.7",
		"@types/madge": "^5.0.3",
		"@types/node": "^24.10.9",
		"concurrently": "^9.2.1",
		"drizzle-dbml-generator": "^0.10.0",
		"husky": "^9.1.7",
		"madge": "^8.0.0",
		"wait-on": "^9.0.3"
	},
	"peerDependencies": {
		"typescript": "^5.9.3",
		"openapi-fetch": "^0.14.1",
		"koritsu": "^0.1.19",
		"valibot": "^1.2.0"
	},
	"resolutions": {
		"svelte": "^5.43.15",
		"lightningcss": "1.30.1",
		"react-test-renderer": "19.1.0",
		"@better-auth/core": "1.5.5"
	},
	"workspaces": [
		"packages/*"
	]
}
