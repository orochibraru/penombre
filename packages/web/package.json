{
	"name": "@opendrive/web",
	"private": true,
	"version": "0.0.7",
	"type": "module",
	"packageManager": "bun@1.3.1",
	"scripts": {
		"preinstall": "bunx only-allow bun",
		"dev": "bunx --bun vite dev",
		"build": "bunx --bun svelte-kit sync && bunx --bun vite build",
		"preview": "bunx --bun vite preview",
		"prepare": "bunx --bun svelte-kit sync || echo ''",
		"check": "bunx --bun svelte-kit sync && bunx --bun svelte-check --tsconfig ./tsconfig.json",
		"gen:api": "bunx --bun openapi-typescript ../api/openapi.json -o ./src/lib/api/schema.d.ts && biome format ./src/lib/api/schema.d.ts --write",
		"gen:routes": "bunx --bun kit-routes sync",
		"db:generate": "bunx --bun drizzle-kit generate",
		"gen:env": "bun run scripts/generate-env-example.ts"
	},
	"devDependencies": {
		"@shikijs/langs": "^3.21.0",
		"@shikijs/themes": "^3.21.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.49.3",
		"@sveltejs/vite-plugin-svelte": "^6.2.3",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/bun": "^1.3.5",
		"@types/node": "^24.10.4",
		"@types/nodemailer": "^7.0.5",
		"@types/sharp": "^0.32.0",
		"bits-ui": "^2.15.4",
		"bun": "^1.3.5",
		"changelogen": "^0.6.2",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.8",
		"openapi-typescript": "^7.10.1",
		"runed": "^0.34.0",
		"shiki": "^3.21.0",
		"svelte": "^5.46.1",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.3.5",
		"svelte-toolbelt": "^0.10.6",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-kit-routes": "^1.0.2"
	},
	"dependencies": {
		"@hono/zod-validator": "^0.7.6",
		"@internationalized/date": "^3.10.1",
		"@kitql/helpers": "^0.8.13",
		"@lucide/svelte": "^0.545.0",
		"better-auth": "^1.4.10",
		"bullmq": "^5.66.5",
		"drizzle-orm": "^0.45.1",
		"drizzle-zod": "^0.8.3",
		"hono": "^4.11.3",
		"layerchart": "2.0.0-next.19",
		"mode-watcher": "^1.1.0",
		"music-metadata": "^11.10.5",
		"nodemailer": "^7.0.12",
		"paneforge": "1.0.2",
		"postgres": "^3.4.8",
		"sharp": "^0.34.5",
		"svelte-sonner": "^1.0.7",
		"sveltekit-superforms": "^2.29.1",
		"tw-animate-css": "^1.4.0",
		"uuid": "^13.0.0",
		"valibot": "^1.2.0",
		"vaul-svelte": "1.0.0-next.7",
		"zod": "^4.3.5"
	}
}
