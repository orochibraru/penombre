{
	"name": "@penombre/web",
	"type": "module",
	"packageManager": "bun@1.3.11",
	"scripts": {
		"preinstall": "bunx only-allow bun",
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"gen:api": "bun run scripts/generate-openapi.ts && openapi-typescript ./src/lib/api/v1.json -o ./src/lib/api/v1.d.ts",
		"gen:routes": "kit-routes sync",
		"db:generate": "drizzle-kit generate",
		"migrate:storage": "bun run scripts/migrate-storage-meta.ts",
		"gen:env": "bun run scripts/generate-env-example.ts",
		"machine-translate": "inlang machine translate --project project.inlang",
		"db:studio": "drizzle-kit studio",
		"test:e2e": "docker compose -f ../../compose.e2e.yaml -p penombre-e2e build && playwright test --config=playwright.local.config.ts",
		"test:e2e:s3": "docker compose -f ../../compose.e2e.yaml --profile s3 -p penombre-e2e-s3 build && playwright test --config=playwright.config.ts",
		"test:e2e:local": "docker compose -f ../../compose.e2e.yaml -p penombre-e2e build && playwright test --config=playwright.local.config.ts",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed"
	},
	"devDependencies": {
		"@inlang/cli": "^3.1.9",
		"@inlang/paraglide-js": "^2.15.1",
		"@playwright/test": "^1.59.1",
		"@shikijs/langs": "^4.0.2",
		"@shikijs/themes": "^4.0.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/archiver": "^7.0.0",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.1",
		"@types/nodemailer": "^7.0.11",
		"@types/sharp": "^0.32.0",
		"@vite-pwa/sveltekit": "^1.1.0",
		"bits-ui": "^2.16.5",
		"bun": "^1.3.11",
		"changelogen": "^0.6.2",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"openapi-typescript": "^7.13.0",
		"runed": "^0.37.1",
		"shiki": "^4.0.2",
		"svelte": "^5.55.1",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.6",
		"svelte-toolbelt": "^0.10.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.3"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1023.0",
		"@better-auth/api-key": "^1.5.6",
		"@better-auth/core": "^1.5.6",
		"@better-auth/expo": "^1.5.6",
		"@better-auth/passkey": "^1.5.6",
		"@internationalized/date": "^3.12.0",
		"@kitql/helpers": "^0.8.13",
		"@lucide/svelte": "^1.7.0",
		"archiver": "^7.0.1",
		"better-auth": "^1.5.6",
		"drizzle-orm": "^0.45.2",
		"drizzle-zod": "^0.8.3",
		"ioredis": "^5.10.1",
		"layerchart": "2.0.0-next.46",
		"mode-watcher": "^1.1.0",
		"music-metadata": "^11.12.3",
		"nodemailer": "^8.0.4",
		"openapi-fetch": "^0.17.0",
		"paneforge": "1.0.2",
		"postgres": "^3.4.8",
		"sharp": "^0.34.5",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.1",
		"tw-animate-css": "^1.4.0",
		"uuid": "^13.0.0",
		"valibot": "^1.3.1",
		"vaul-svelte": "1.0.0-next.7",
		"zod": "^4.3.6"
	}
}
