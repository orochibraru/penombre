{
	"compilerOptions": {
		"moduleResolution": "node10",
		"ignoreDeprecations": "6.0",
		"module": "commonjs",
		"target": "es2022",
		"lib": ["es2022", "DOM"],
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": false,
		"noEmit": true,
		"types": ["node"]
	},
	"include": ["./**/*.ts"]
}
