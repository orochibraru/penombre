{
	"name": "@opendrive/ui",
	"private": true,
	"version": "0.0.7",
	"type": "module",
	"packageManager": "pnpm@10.12.4",
	"scripts": {
		"dev": "vite dev",
		"dev:silent": "vite dev --logLevel warn",
		"build": "svelte-kit sync && vite build",
		"start": "node ./build/index.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"circular": "node circular.ts",
		"lint": "biome check ./src/",
		"lint:fix": "biome check --fix ./src/ && pnpm format",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"format": "prettier --write --log-level warn .",
		"format:check": "prettier --check --log-level warn .",
		"gen:api": "openapi-typescript ../api/public/openapi.json -o ./src/lib/api/schema.d.ts",
		"gen:routes": "kit-routes sync"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@capacitor/cli": "^7.4.3",
		"@dnd-kit-svelte/core": "^0.0.11",
		"@dnd-kit-svelte/modifiers": "^0.0.11",
		"@dnd-kit-svelte/sortable": "^0.0.11",
		"@dnd-kit-svelte/utilities": "^0.0.11",
		"@shikijs/langs": "^3.13.0",
		"@shikijs/themes": "^3.13.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.46.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.14",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.7",
		"@types/madge": "^5.0.3",
		"@types/mime-types": "^3.0.1",
		"@types/node": "^24.7.2",
		"bits-ui": "^2.11.5",
		"changelogen": "^0.6.2",
		"clsx": "^2.1.1",
		"jsdom": "^27.0.0",
		"madge": "^8.0.0",
		"openapi-typescript": "^7.9.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"runed": "^0.34.0",
		"shiki": "^3.13.0",
		"svelte": "^5.39.11",
		"svelte-check": "^4.3.3",
		"svelte-toolbelt": "^0.10.5",
		"sveltekit-sse": "^0.14.3",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.1.1",
		"tailwindcss": "^4.1.14",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vite": "^7.1.9",
		"vite-plugin-kit-routes": "^1.0.2",
		"vitepress": "^1.6.4"
	},
	"dependencies": {
		"@capacitor/android": "^7.4.3",
		"@capacitor/core": "^7.4.3",
		"@capacitor/ios": "^7.4.3",
		"@happy-dom/global-registrator": "^20.0.0",
		"@internationalized/date": "^3.10.0",
		"@kitql/helpers": "^0.8.13",
		"@lucide/svelte": "^0.545.0",
		"@tanstack/table-core": "^8.21.3",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"dotenv": "^17.2.3",
		"esbuild": "^0.25.10",
		"formsnap": "^2.0.1",
		"layerchart": "2.0.0-next.19",
		"mime-types": "^3.0.1",
		"mode-watcher": "^1.1.0",
		"music-metadata": "^11.9.0",
		"nanoid": "^5.1.6",
		"openapi-fetch": "^0.14.1",
		"paneforge": "1.0.2",
		"picocolors": "^1.1.1",
		"svelte-pdf": "^1.0.28",
		"svelte-sonner": "^1.0.5",
		"sveltekit-superforms": "^2.27.2",
		"tw-animate-css": "^1.4.0",
		"uuid": "^13.0.0",
		"valibot": "^1.1.0",
		"vaul-svelte": "1.0.0-next.7",
		"zod": "^4.1.12"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"cpu-features",
			"esbuild",
			"msgpackr-extract",
			"protobufjs",
			"ssh2"
		]
	},
	"engines": {
		"node": "^24"
	}
}
