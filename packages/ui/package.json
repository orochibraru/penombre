{
	"name": "@opendrive/ui",
	"private": true,
	"version": "0.0.7",
	"type": "module",
	"packageManager": "bun@1.3.1",
	"scripts": {
		"preinstall": "bunx only-allow bun",
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"gen:api": "openapi-typescript ../api/openapi.json -o ./src/lib/api/schema.d.ts && biome format ./src/lib/api/schema.d.ts --write",
		"gen:routes": "kit-routes sync"
	},
	"devDependencies": {
		"@shikijs/langs": "^3.15.0",
		"@shikijs/themes": "^3.15.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.49.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^24.10.1",
		"bits-ui": "^2.14.4",
		"changelogen": "^0.6.2",
		"clsx": "^2.1.1",
		"openapi-typescript": "^7.10.1",
		"runed": "^0.34.0",
		"shiki": "^3.15.0",
		"svelte": "^5.43.15",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.3.4",
		"svelte-toolbelt": "^0.10.6",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.17",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"vite": "^7.2.4",
		"vite-plugin-kit-routes": "^1.0.2"
	},
	"dependencies": {
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.545.0",
		"better-auth": "^1.4.1",
		"layerchart": "2.0.0-next.19",
		"mode-watcher": "^1.1.0",
		"openapi-fetch": "^0.14.1",
		"paneforge": "1.0.2",
		"svelte-sonner": "^1.0.6",
		"sveltekit-superforms": "^2.28.1",
		"tw-animate-css": "^1.4.0",
		"uuid": "^13.0.0",
		"valibot": "^1.2.0",
		"vaul-svelte": "1.0.0-next.7",
		"zod": "^4.1.13"
	}
}
