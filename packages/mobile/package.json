{
	"name": "@penombre/mobile",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"dev": "bunx --bun expo start",
		"reset-project": "node ./scripts/reset-project.js",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"gen:api": "openapi-typescript ./assets/api.v1.json --output ./lib/api.v1.d.ts",
		"web": "expo start --web",
		"check": "tsc --noEmit",
		"build:android": "node ./scripts/link-hermesc.cjs && cd android && ./gradlew assembleRelease",
		"build:android:debug": "node ./scripts/link-hermesc.cjs && cd android && ./gradlew assembleDebug",
		"pods:install": "cd ios && (POD_BIN=$(command -v pod || true); if [ -z \"$POD_BIN\" ] && [ -x \"$HOME/.gem/ruby/2.6.0/bin/pod\" ]; then POD_BIN=\"$HOME/.gem/ruby/2.6.0/bin/pod\"; fi; if [ -z \"$POD_BIN\" ]; then echo 'CocoaPods is required. Install with: gem install --user-install cocoapods'; exit 1; fi; if [ \"$POD_BIN\" = \"$HOME/.gem/ruby/2.6.0/bin/pod\" ]; then RUBYOPT='-rlogger' \"$POD_BIN\" install; else \"$POD_BIN\" install; fi)",
		"build:ios": "bun run pods:install && cd ios && xcodebuild -workspace opendrive.xcworkspace -scheme opendrive -configuration Release -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' build",
		"build:ios:debug": "bun run pods:install && cd ios && xcodebuild -workspace opendrive.xcworkspace -scheme opendrive -configuration Debug -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' build"
	},
	"dependencies": {
		"@better-auth/expo": "^1.6.0",
		"@better-auth/passkey": "^1.6.0",
		"@expo/ngrok": "^4.1.3",
		"@expo/vector-icons": "^15.1.1",
		"@react-navigation/bottom-tabs": "^7.15.9",
		"@react-navigation/elements": "^2.9.14",
		"@react-navigation/native": "^7.2.2",
		"better-auth": "^1.6.0",
		"expo": "~55.0.12",
		"expo-constants": "^55.0.12",
		"expo-font": "~55.0.6",
		"expo-haptics": "~55.0.13",
		"expo-image": "~55.0.8",
		"expo-linking": "^55.0.11",
		"expo-network": "^55.0.12",
		"expo-router": "^55.0.11",
		"expo-secure-store": "^55.0.12",
		"expo-splash-screen": "~55.0.16",
		"expo-status-bar": "~55.0.5",
		"expo-symbols": "~55.0.7",
		"expo-system-ui": "~55.0.14",
		"expo-web-browser": "^55.0.13",
		"nativewind": "^5.0.0-preview.3",
		"openapi-fetch": "^0.17.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-native": "0.83.4",
		"react-native-css": "^3.0.7",
		"react-native-gesture-handler": "~2.31.0",
		"react-native-reanimated": "^4.3.0",
		"react-native-safe-area-context": "^5.7.0",
		"react-native-screens": "~4.24.0",
		"react-native-web": "~0.21.2",
		"react-native-worklets": "0.8.1",
		"swr": "^2.4.1"
	},
	"devDependencies": {
		"@expo/metro-config": "~55.0.14",
		"@tailwindcss/postcss": "^4.2.2",
		"@types/react": "~19.2.14",
		"openapi-typescript": "^7.13.0",
		"postcss": "^8.5.9",
		"tailwindcss": "^4.2.2",
		"typescript": "~6.0.2"
	},
	"private": true
}
