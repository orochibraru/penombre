{
	"name": "@opendrive/api",
	"module": "index.ts",
	"type": "module",
	"scripts": {
		"preinstall": "bunx only-allow bun",
		"dev": "bun --hot index.ts",
		"start": "ENV=production bun run ./index.ts",
		"check": "tsc --project ./tsconfig.json",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun run ./migrate.ts",
		"build": "bun run --cwd ../ui build && rm -rf ./frontend && mkdir -p ./frontend && cp -r ../ui/build/* ./frontend/"
	},
	"private": true,
	"devDependencies": {
		"@types/bun": "latest",
		"bun": "^1.3.2",
		"drizzle-kit": "^0.31.7"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"better-auth": "^1.3.34",
		"drizzle-orm": "^0.44.7",
		"drizzle-zod": "^0.8.3",
		"koritsu": "^0.1.18",
		"music-metadata": "^11.10.1",
		"ts-to-zod": "^5.0.1",
		"zod": "^4.1.12"
	}
}
