#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-commit hooks..."

echo "Generating default env config"
bun run --filter @penombre/web gen:env

echo "Generating DB diagram..."
bun run db:diagram

echo "Generating API clients..."
bun run gen:api

echo "Running tests..."
if bun test --coverage; then
    echo "Tests passed."
else
    echo "Tests failed. Please fix the issues before committing."
    exit 1
fi

echo "Linting, formatting and fixing issues..."
if bunx --bun biome check --write; then
    echo "Linting passed."
else
    echo "Linting issues found. Please run 'bunx --bun biome check --write' to fix them."
    exit 1
fi

# Formatting is bound to change some files, let's check out which ones and stage them if needed
FORMATTED_FILES=$(git diff --name-only --diff-filter=ACM)

if [[ -z "$FORMATTED_FILES" ]]; then
    echo "No files were formatted."
    exit 0
fi

# Loop over the staged files and add any changes made by the pre-commit hooks
for file in $FORMATTED_FILES; do
    if [[ -f "$file" ]]; then
        echo "Staging changes for $file after formatting."
        git add "$file"
    fi
done
