#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-commit hooks..."

echo "Generating default env config"
bun run --filter @penombre/web gen:env


echo "Generating DB diagram..."
bun run db:diagram

echo "Generating API clients..."
bun run gen:api

echo "Running tests..."
if bun test --coverage; then
    echo "Tests passed."
else
    echo "Tests failed. Please fix the issues before committing."
    exit 1
fi

echo "Linting, formatting and fixing issues..."
if bunx --bun biome check --write; then
    echo "Linting passed."
else
    echo "Linting issues found. Please run 'bunx --bun biome check --write' to fix them."
    exit 1
fi


echo "Staging changes..."
git add .
