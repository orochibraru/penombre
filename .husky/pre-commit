#!/usr/bin/env bash
set -euo pipefail

echo "⏳ Running lint-staged..."
export NODE_OPTIONS="--experimental-strip-types --disable-warning=ExperimentalWarning"
if pnpm exec lint-staged --config lint-staged.config.mjs; then
    echo "✅ Lint staged ran successfully"
else
    echo "🔴 Failed to run Lint staged"
    exit 1
fi
