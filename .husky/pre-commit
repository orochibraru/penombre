#!/usr/bin/env bash
set -euo pipefail

echo "Running pre-commit hooks..."

echo "Linting, formatting and fixing issues..."
if bunx --bun biome check --write; then
    echo "Linting passed."
else
    echo "Linting issues found. Please run 'bunx --bun biome check --write' to fix them."
    exit 1
fi


echo "Staging changes..."
git add .
